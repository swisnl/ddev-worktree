#!/usr/bin/env bash

## Description: Remove a worktree and its associated DDEV project cleanly
## Usage: worktree-remove <branch> [extra git worktree remove flags...]
## Example: "ddev worktree-remove feat/login"
## OSTypes: darwin,linux
#ddev-generated

# Companion to `ddev worktree-provision` — that one creates the DDEV project
# and worktree state; this one tears it all down cleanly.
#
#   ddev worktree-remove feat/login          # normal remove
#   ddev worktree-remove feat/login --force  # force-remove, discarding tracked edits too
#   ddev worktree-remove --here              # tear down only the DDEV project for
#                                            # the current worktree, leaving the git
#                                            # worktree for an external manager
#                                            # (e.g. worktrunk) to remove
#
# Provisioning leaves untracked files in the worktree (the copied .env,
# .ddev/config.local.yaml, installed deps), which would make a plain
# `git worktree remove` refuse. So when no flags are given this command removes
# the worktree even with such generated/untracked files present, but still
# refuses if there are uncommitted changes to *tracked* files — pass --force to
# discard those too.
#
# Tolerant of partial state — the DDEV project may already be gone, or the
# worktree directory may have been removed manually. Either way, this command
# brings everything to a clean end state.

set -euo pipefail

# Anchor to the project root; git commands below then run against this repo.
# In --here mode DDEV_APPROOT is unset (we're invoked from a worktree manager's
# hook), so this resolves to the current worktree — which is what we want.
cd "${DDEV_APPROOT:-$PWD}"

# Split --here (tear down only the DDEV project, leave the git worktree for the
# external manager) from the branch arg + any pass-through git worktree flags.
HERE=""
ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --here) HERE=1; shift ;;
    *) ARGS+=("$1"); shift ;;
  esac
done
if [[ ${#ARGS[@]} -gt 0 ]]; then set -- "${ARGS[@]}"; else set --; fi

if [[ $# -lt 1 && -z "$HERE" ]]; then
  echo "Usage: ddev worktree-remove <branch> [extra git worktree remove flags...]" >&2
  echo "       ddev worktree-remove --here   # remove only the DDEV project for the current worktree" >&2
  exit 1
fi

BRANCH="${1:-}"
[[ $# -gt 0 ]] && shift

sanitize() {
  printf '%s' "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9-]+/-/g; s/-+/-/g; s/^-//; s/-$//'
}

# In --here mode the current worktree is the target and its branch names it.
[[ -n "$HERE" && -z "$BRANCH" ]] && BRANCH=$(git rev-parse --abbrev-ref HEAD)

SANITIZED=$(sanitize "$BRANCH")
MAIN_ROOT=$(git worktree list --porcelain | sed -n 's/^worktree //p' | head -n 1)
if [[ -n "$HERE" ]]; then
  WORKTREE_PATH="$PWD"
else
  # Sanitized to match the convention worktree-provision documents:
  #   git worktree add .worktrees/<sanitized-branch> <branch>
  WORKTREE_PATH="$MAIN_ROOT/.worktrees/$SANITIZED"
fi

# Resolve the DDEV project name without hardcoding a prefix. Prefer the name
# worktree-provision wrote into the worktree's own config.local.yaml; else
# fall back to <base>-<branch>, where <base> is this base project's DDEV name
# (DDEV_SITENAME when run as `ddev worktree-remove`, else read from config).
PROJECT=""
if [[ -f "$WORKTREE_PATH/.ddev/config.local.yaml" ]]; then
  PROJECT=$(sed -nE "s/^name:[[:space:]]*//p" "$WORKTREE_PATH/.ddev/config.local.yaml" | head -n1 | tr -d "\"'")
fi
if [[ -z "$PROJECT" ]]; then
  BASE_NAME="${DDEV_SITENAME:-}"
  if [[ -z "$BASE_NAME" ]]; then
    for f in "$MAIN_ROOT/.ddev/config.local.yaml" "$MAIN_ROOT/.ddev/config.yaml"; do
      [[ -f "$f" ]] || continue
      BASE_NAME=$(sed -nE "s/^name:[[:space:]]*//p" "$f" | head -n1 | tr -d "\"'")
      [[ -n "$BASE_NAME" ]] && break
    done
  fi
  [[ -n "$BASE_NAME" ]] && PROJECT="${BASE_NAME}-${SANITIZED}"
fi

# Step 1: tear down the DDEV project if it exists.
if ! command -v ddev >/dev/null 2>&1; then
  echo "[worktree-remove] ddev not on PATH; skipping DDEV teardown" >&2
elif [[ -z "$PROJECT" ]]; then
  echo "[worktree-remove] could not resolve a DDEV project name; skipping DDEV teardown" >&2
elif ddev describe "$PROJECT" -j >/dev/null 2>&1; then
  echo "[worktree-remove] tearing down DDEV project '$PROJECT'"
  ddev delete -Oy "$PROJECT"
else
  echo "[worktree-remove] no DDEV project '$PROJECT' to delete"
fi

# Step 2: remove the worktree (or prune stale registration if it's already gone).
# In --here mode we stop here: the external manager (worktrunk) owns the git
# worktree and will remove it after this hook returns.
if [[ -n "$HERE" ]]; then
  echo "[worktree-remove] --here: leaving the git worktree for the external manager to remove"
elif [[ ! -d "$WORKTREE_PATH" ]]; then
  echo "[worktree-remove] $WORKTREE_PATH not on disk; pruning stale registrations"
  git worktree prune
elif [[ $# -gt 0 ]]; then
  # Caller passed explicit flags (e.g. --force); respect them verbatim.
  echo "[worktree-remove] removing worktree at $WORKTREE_PATH"
  git worktree remove "$@" "$WORKTREE_PATH"
else
  echo "[worktree-remove] removing worktree at $WORKTREE_PATH"
  if git worktree remove "$WORKTREE_PATH" 2>/dev/null; then
    :
  elif [[ -z "$(git -C "$WORKTREE_PATH" status --porcelain --untracked-files=no)" ]]; then
    # Nothing but provisioning-generated / untracked files stood in the way
    # (no uncommitted changes to tracked files) — safe to force.
    echo "[worktree-remove] only generated/untracked files present; forcing removal"
    git worktree remove --force "$WORKTREE_PATH"
  else
    echo "[worktree-remove] worktree has uncommitted changes to tracked files;" >&2
    echo "                  refusing to discard them. Re-run to override:" >&2
    echo "                    ddev worktree-remove $BRANCH --force" >&2
    exit 1
  fi
fi

echo "[worktree-remove] done"
